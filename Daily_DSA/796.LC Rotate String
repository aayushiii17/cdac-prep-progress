Example 1:

Input: s = "abcde", goal = "cdeab"
Output: true
Example 2:

Input: s = "abcde", goal = "abced"
Output: false
 ---------------------code--------------------
class Solution {
    public boolean rotateString(String s, String goal) {
        for(int i =0; i<s.length();i++){
            if(s.equals(goal)) return true;

            s= s.substring(1)+s.charAt(0);
        }
        return false;

        
        
    }
}
