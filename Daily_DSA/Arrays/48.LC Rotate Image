48. Rotate Image
Input: matrix = [[1,2,3],[4,5,6],[7,8,9]]
Output: [[7,4,1],[8,5,2],[9,6,3]]

class Solution {
    public void rotate(int[][] matrix) {
        int n = matrix.length;
        //1.Transpose a matrix row into column
        for(int i = 0; i<n; i++){
            for(int j=i; j<n;j++){
                int temp = matrix[i][j];
                matrix[i][j] = matrix[j][i];
                matrix[j][i]=temp;
            }
        }
        //2. reverse each row
        for(int i = 0; i<n; i++){
            int left =0;
            int right = n-1;
            while(left<right){
                int temp = matrix[i][left];
                matrix[i][left] = matrix[i][right];
                matrix[i][right]=temp;
                left++;
                right--;
            }
        }
        
    }
}
